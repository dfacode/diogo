<mvc:View
    controllerName="diogo.controller.View"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:m="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns="sap.uxap"
>
    <ObjectPageLayout id="ObjectPageLayout" preserveHeaderStateOnScroll="true" upperCaseAnchorBar="false">

        <headerContent>
            <m:FlexBox justifyContent="SpaceBetween" alignItems="Center" width="100%">
                <m:Avatar id="avatar" displaySize="L" src="https://avatars.githubusercontent.com/u/88743618?v=4"/>
                <m:Button text="{i18n>languageButton}" press=".onLanguageToggle" type="Default"/>
            </m:FlexBox>
        </headerContent>

        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <heading>
                    <m:Title text="Diogo Ferreira Alves" />
                </heading>

                <expandedContent>
                    <m:Title text="Certified SAP ABAP HCM Developer" />
                </expandedContent>
            </ObjectPageDynamicHeaderTitle> 
        </headerTitle>

        <headerContent>
            <m:FlexBox wrap="Wrap" fitContainer="true">
                <l:VerticalLayout class="sapUiSmallMarginEnd">
                    <m:ObjectStatus title="" text=""/>
                    <m:ObjectStatus title="{i18n>localization}" text="São Paulo/SP - Brazil"/>
                    <m:ObjectStatus title="{i18n>phone}" text="+55 11 94821-8885"/>
                    <m:ObjectStatus title="{i18n>email}" text="ddfalves@gmail.com"/>
                </l:VerticalLayout>
            </m:FlexBox>

            <m:FlexBox wrap="Wrap" fitContainer="true">
                <l:VerticalLayout class="sapUiSmallMarginEnd">
                    <m:Link text="{i18n>linkedin}" href="https://www.linkedin.com/in/diogo-f-23300b83/" target="_blank"/>
                    <m:Link text="{i18n>github}" href="https://github.com/dfacode" target="_blank"/>                    
                </l:VerticalLayout>
            </m:FlexBox>

        </headerContent>

        <sections>
            <ObjectPageSection titleUppercase="false" title="{i18n>aboutMe}">
                <subSections>
                    <ObjectPageSubSection>
                        <l:VerticalLayout class="sapUiSmallMargin">
                            <m:Text text="{i18n>text1}"/>
                            <m:Text text="{i18n>text2}"/>
                            <m:Text text="{i18n>text3}"/>
                            <m:Text text="{i18n>text4}"/>
                            <m:Text text="{i18n>text5}"/>
                            <m:Text text="{i18n>text6}"/>
                            <m:Text text="{i18n>text7}"/>
                            <m:Text text="{i18n>text8}"/>
                            <m:Text text="{i18n>text9}"/>
                        </l:VerticalLayout>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection titleUppercase="false" title="{i18n>academicBackground}">
                <subSections>
                    <ObjectPageSubSection>
                        <l:VerticalLayout class="sapUiSmallMargin">
                            <m:Text text="{i18n>text10}"/>
                            <m:Text text="{i18n>text11}"/>
                        </l:VerticalLayout>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>                

            <ObjectPageSection titleUppercase="false" title="{i18n>professionalBackground}">
                <subSections>
                    <ObjectPageSubSection title="{i18n>text12}" titleUppercase="false">
                        <l:VerticalLayout class="sapUiSmallMargin">
                            <m:Text text="{i18n>text13}"/>
                            <m:Text text="{i18n>text14}"/>
