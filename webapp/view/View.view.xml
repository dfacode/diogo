<mvc:View
    controllerName="diogo.controller.View"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns:m="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns="sap.uxap"
>
    <ObjectPageLayout id="ObjectPageLayout" preserveHeaderStateOnScroll="true" upperCaseAnchorBar="false">

        <headerContent>
            <m:Avatar id="avatar" displaySize="L" src="https://avatars.githubusercontent.com/u/110328064?v=4"/>
        </headerContent>

        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <heading>
                    <m:Title text="Diogo Ferreira Alves" />
                </heading>

                <expandedContent>
                    <m:Title text="Certified SAP ABAP HCM Developer" />
                </expandedContent>
            </ObjectPageDynamicHeaderTitle> 
        </headerTitle>

		<headerContent>
			<m:FlexBox wrap="Wrap" fitContainer="true">
				<l:VerticalLayout class="sapUiSmallMarginEnd">
                    <m:ObjectStatus title="" text=""/>
					<m:ObjectStatus title="Localization" text="São Paulo/SP - Brazil"/>
					<m:ObjectStatus title="Phone" text="+55 11 94821-8885"/>
					<m:ObjectStatus title="e-mail" text="ddfalves@gmail.com"/>
				</l:VerticalLayout>
			</m:FlexBox>
		</headerContent>

        <sections>
			<ObjectPageSection titleUppercase="false" title="About Me">
				<subSections>
                    <ObjectPageSubSection>
                        <l:VerticalLayout class="sapUiSmallMargin">
                            <m:Text text="{i18n>text1}"/>
